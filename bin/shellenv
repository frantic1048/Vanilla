#!/usr/bin/env bash

# Bootstrap only: put Homebrew's bin on PATH so `nu` is findable,
# then hand off to the shellenv.nu.
if [ "$(uname -s)" = "Darwin" ]; then
  if [ "$(uname -m)" = "arm64" ]; then
    export PATH="/opt/homebrew/bin:$PATH"
  else
    export PATH="/usr/local/bin:$PATH"
  fi
fi

SCRIPT_DIR=$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" &>/dev/null && pwd)

exec nu --no-config-file "$SCRIPT_DIR/shellenv.nu" "$@"
